# ----- Database (Postgres + Prisma) -----
# docker-compose reads POSTGRES_* to auto-create the role + database on first boot.
POSTGRES_USER="hmd"
POSTGRES_PASSWORD="hmd_demo_pw"   # CHANGE on Frankfurt — use a strong value
POSTGRES_DB="hmd_crm"
# Local NATIVE run uses localhost. Under docker compose the app service overrides
# this to host "db" automatically (see docker-compose.yml), so leave as localhost here.
DATABASE_URL="postgresql://hmd:hmd_demo_pw@localhost:5432/hmd_crm?schema=public"

# ----- Auth.js / NextAuth -----
AUTH_SECRET="dev-secret-change-me"
NEXTAUTH_SECRET="dev-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"
# Frankfurt demo: http://wichai.xyz:3000
APP_URL="http://localhost:3000"

# Demo role-switch fallback (no real SSO). Set true for the hackathon demo.
DEMO_MODE="true"

# ----- Microsoft Entra ID SSO (optional, production auth — deferred for the demo) -----
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# ----- AI provider: Featherless (OpenAI-compatible). Team has the key. -----
# AI features degrade to a deterministic fallback when these are unset.
FEATHERLESS_API_KEY=""
FEATHERLESS_MODEL="Qwen/Qwen2.5-7B-Instruct"
FEATHERLESS_BASE_URL="https://api.featherless.ai/v1"
