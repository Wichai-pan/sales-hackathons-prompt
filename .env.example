# ----- Database (Postgres + Prisma) -----
# Local dev: docker-compose Postgres OR a native Postgres install.
DATABASE_URL="postgresql://hmd:hmd@localhost:5432/hmd_crm?schema=public"

# ----- Auth.js / NextAuth -----
AUTH_SECRET="dev-secret-change-me"
NEXTAUTH_SECRET="dev-secret-change-me"
NEXTAUTH_URL="http://localhost:3000"
APP_URL="http://localhost:3000"

# Demo role-switch fallback (no real SSO). Set true for the hackathon demo.
DEMO_MODE="true"

# ----- Microsoft Entra ID SSO (optional, production auth) -----
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# ----- Azure OpenAI (optional — AI features degrade to deterministic fallback) -----
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_DEPLOYMENT=""
